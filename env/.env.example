# New namespace (canonical): APP__<DOMAIN>__<FIELD>.
# Policy reference (what goes to YAML vs ENV): docs/configuration-source-policy.md
APP__APP__ENV=local
APP__APP__VERSION=dev
APP__HTTP__ADDR=:8080
APP__HTTP__SHUTDOWN_TIMEOUT=30s
APP__HTTP__READINESS_TIMEOUT=3s
APP__HTTP__READINESS_PROPAGATION_DELAY=15s
APP__HTTP__READ_HEADER_TIMEOUT=5s
APP__HTTP__READ_TIMEOUT=5s
APP__HTTP__WRITE_TIMEOUT=10s
APP__HTTP__IDLE_TIMEOUT=60s
APP__HTTP__MAX_HEADER_BYTES=16384
APP__HTTP__MAX_BODY_BYTES=1048576
APP__LOG__LEVEL=info
APP__OBSERVABILITY__OTEL__SERVICE_NAME=service
APP__OBSERVABILITY__OTEL__TRACES_SAMPLER=parentbased_traceidratio
APP__OBSERVABILITY__OTEL__TRACES_SAMPLER_ARG=0.10
APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_ENDPOINT=
APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_TRACES_ENDPOINT=
APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_HEADERS=
APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_PROTOCOL=http/protobuf

# Postgres (if enabled).
APP__POSTGRES__ENABLED=false
APP__POSTGRES__DSN=

# Redis/Mongo are additive domains in v1 and disabled by default.
APP__REDIS__ENABLED=false
APP__REDIS__MODE=cache
APP__REDIS__ALLOW_STORE_MODE=false
APP__MONGO__ENABLED=false
APP__MONGO__URI=
APP__MONGO__DATABASE=app

# Bootstrap-owned network policy controls. Keep examples commented so local
# copies do not silently declare production ingress or exception policy.
# NETWORK_PUBLIC_INGRESS_ENABLED=false
# NETWORK_EGRESS_ALLOWLIST=api.example.com,*.internal.example.com
# NETWORK_EGRESS_ALLOWED_SCHEMES=tcp,https
# NETWORK_INGRESS_EXCEPTION_ACTIVE=false
# NETWORK_INGRESS_EXCEPTION_ID=
# NETWORK_INGRESS_EXCEPTION_OWNER=
# NETWORK_INGRESS_EXCEPTION_REASON=
# NETWORK_INGRESS_EXCEPTION_SCOPE=
# NETWORK_INGRESS_EXCEPTION_EXPIRY=
# NETWORK_INGRESS_EXCEPTION_ROLLBACK_PLAN=
# NETWORK_EGRESS_EXCEPTION_ACTIVE=false
# NETWORK_EGRESS_EXCEPTION_ID=
# NETWORK_EGRESS_EXCEPTION_OWNER=
# NETWORK_EGRESS_EXCEPTION_REASON=
# NETWORK_EGRESS_EXCEPTION_SCOPE=
# NETWORK_EGRESS_EXCEPTION_EXPIRY=
# NETWORK_EGRESS_EXCEPTION_ROLLBACK_PLAN=

# Optional OTLP exporter settings for trace export.
# APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_ENDPOINT=http://localhost:4318
# APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_TRACES_ENDPOINT=
# APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_HEADERS=
# APP__OBSERVABILITY__OTEL__EXPORTER__OTLP_PROTOCOL=http/protobuf
